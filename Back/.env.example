# ==================== .env.example ====================
# Archivo: Back/.env.example
# Descripción: Plantilla para variables de entorno.
# Copia este archivo a .env en la raíz del proyecto.
# ========================================================

# ── Cuenta objetivo ──────────────────────────────────────
TARGET_ACCOUNT=username_de_la_cuenta_publica

# ── Cookies de identidad (copiar desde DevTools) ─────────
# DevTools -> Application -> Storage -> Cookies -> https://www.instagram.com
IG_SESSION_ID=tu_session_id_aqui
IG_MID=tu_mid_aqui
IG_DID=tu_ig_did_aqui
IG_NRCB=1
IG_CSRFTOKEN=tu_csrftoken_aqui
IG_DATR=tu_datr_aqui
IG_DS_USER_ID=tu_user_id_numerico

# ── App ID de Instagram Web (opcional) ───────────────────
IG_APP_ID=936619743392459

# ── Límites de extracción (Académico: 10/10) ──────────────
POSTS_LIMIT=10
COMMENTS_LIMIT=10

# ── Opciones de Playwright ────────────────────────────────
PLAYWRIGHT_HEADLESS=true

# ── Inteligencia Artificial (Análisis OCEAN) ──────────────
# Obtén tu API Key en: https://console.groq.com/
GROQ_API_KEY=tu_groq_api_key_aqui
GROQ_MODEL=llama-3.3-70b-versatile